// COURSE BUILDER EXTENSION for TEACH Platform
// Add these models to the existing schema.prisma file

// ===== PROJECT MANAGEMENT =====

model Project {
  id          String   @id @default(uuid())
  name        String   // "English A1 Course", "Math Fundamentals", etc.
  description String?
  subject     String   // English, Math, Science, AI, etc.
  language    String   @default("pt-BR")
  
  // Project ownership
  ownerId     String
  owner       User     @relation("ProjectOwner", fields: [ownerId], references: [id])
  
  // Project team
  collaborators ProjectCollaborator[]
  
  // Course content
  courseTemplates CourseTemplate[]
  generatedModules Module[] @relation("ProjectModules")
  generatedLessons Lesson[] @relation("ProjectLessons")
  
  // Project settings
  settings    Json?    // Custom project configuration
  
  // Status
  isActive    Boolean  @default(true)
  isPublished Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("projects")
}

model ProjectCollaborator {
  id        String @id @default(uuid())
  projectId String
  userId    String
  role      ProjectRole @default(COLLABORATOR)
  
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation("ProjectCollaborations", fields: [userId], references: [id], onDelete: Cascade)
  
  addedAt   DateTime @default(now())
  
  @@unique([projectId, userId])
  @@map("project_collaborators")
}

// ===== FLEXIBLE COURSE TEMPLATES =====

model CourseTemplate {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  name        String   // Template name
  description String?
  subject     String   // Subject area
  level       String   // A1, A2, Beginner, Intermediate, etc.
  targetAudience String? // Age group, skill level, etc.
  
  // Template structure
  structure   Json     // Flexible course structure configuration
  duration    Int?     // Total duration in hours
  difficulty  Int      @default(1) // 1-10 scale
  
  // Template components
  moduleTemplates ModuleTemplate[]
  lessonTemplates LessonTemplate[]
  
  // Generation tracking
  generatedCourses Int @default(0)
  lastGenerated    DateTime?
  
  // Template settings
  isPublic    Boolean  @default(false)
  isActive    Boolean  @default(true)
  
  createdBy   String
  creator     User     @relation("CreatedTemplates", fields: [createdBy], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("course_templates")
}

model ModuleTemplate {
  id          String @id @default(uuid())
  templateId  String
  template    CourseTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  
  title       String
  description String?
  order       Int
  duration    Int?   // Duration in hours
  
  // Module configuration
  config      Json?  // Flexible configuration
  objectives  String[] // Learning objectives
  
  // Generated content tracking
  generatedModules Module[] @relation("GeneratedFromTemplate")
  
  // Sub-components
  lessonTemplates LessonTemplate[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("module_templates")
  @@unique([templateId, order])
}

model LessonTemplate {
  id          String @id @default(uuid())
  moduleId    String?
  templateId  String?
  
  moduleTemplate  ModuleTemplate? @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  courseTemplate  CourseTemplate? @relation(fields: [templateId], references: [id], onDelete: Cascade)
  
  title       String
  description String?
  order       Int
  
  // Lesson configuration
  lessonType  LessonType @default(CONTENT)
  deliveryMode DeliveryMode @default(SELF_PACED)
  estimatedDuration Int? // In minutes
  
  // Template content
  contentTemplate String? // Rich text template
  config      Json?       // Flexible lesson configuration
  objectives  String[]    // Learning objectives
  
  // Generated content tracking
  generatedLessons Lesson[] @relation("GeneratedFromTemplate")
  
  // Component templates
  activityTemplates ActivityTemplate[]
  assessmentTemplates AssessmentTemplate[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("lesson_templates")
}

// ===== ACTIVITY & ASSESSMENT TEMPLATES =====

model ActivityTemplate {
  id          String @id @default(uuid())
  lessonId    String
  lesson      LessonTemplate @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  title       String
  description String?
  activityType ActivityType
  order       Int
  
  // Template configuration
  config      Json    // Activity configuration template
  instructions String?
  estimatedTime Int?  // In minutes
  
  // Grading template
  maxPoints   Int?
  isGraded    Boolean @default(false)
  rubric      Json?   // Grading rubric
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("activity_templates")
}

model AssessmentTemplate {
  id          String @id @default(uuid())
  lessonId    String?
  lesson      LessonTemplate? @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  title       String
  description String?
  assessmentType AssessmentType
  
  // Assessment configuration template
  config      Json    // Questions template, grading rules, etc.
  maxScore    Int     @default(100)
  passingScore Int    @default(70)
  timeLimit   Int?    // In minutes
  attempts    Int     @default(3)
  
  // Question bank integration
  questionTemplates QuestionTemplate[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("assessment_templates")
}

// ===== QUESTION BANK SYSTEM =====

model QuestionBank {
  id       String @id @default(uuid())
  projectId String?
  project  Project? @relation(fields: [projectId], references: [id])
  
  name     String
  subject  String
  level    String
  language String @default("pt-BR")
  description String?
  
  // Question organization
  categories String[] // Tags/categories for questions
  
  questions QuestionTemplate[]
  
  // Bank settings
  isPublic Boolean @default(false)
  isActive Boolean @default(true)
  
  createdBy String
  creator   User @relation("CreatedQuestionBanks", fields: [createdBy], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("question_banks")
}

model QuestionTemplate {
  id            String @id @default(uuid())
  assessmentId  String?
  bankId        String?
  
  assessment    AssessmentTemplate? @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  bank          QuestionBank? @relation(fields: [bankId], references: [id])
  
  questionText  String
  questionType  QuestionType
  order         Int?
  points        Int @default(1)
  difficulty    Int @default(1) // 1-10 scale
  
  // Question configuration
  config        Json?   // Flexible question configuration
  
  // Question options template
  options       QuestionOptionTemplate[]
  
  // Correct answers and explanations
  correctAnswers Json   // Flexible structure for different question types
  explanation   String?
  feedback      String? // Additional feedback
  
  // Metadata and tagging
  tags          String[]
  categories    String[]
  keywords      String[]
  
  // Usage tracking
  usageCount    Int @default(0)
  lastUsed      DateTime?
  
  createdBy     String
  creator       User @relation("CreatedQuestions", fields: [createdBy], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@map("question_templates")
}

model QuestionOptionTemplate {
  id         String @id @default(uuid())
  questionId String
  question   QuestionTemplate @relation(fields: [questionId], references: [id], onDelete: Cascade)
  
  optionText String
  isCorrect  Boolean @default(false)
  order      Int
  feedback   String? // Option-specific feedback
  
  // Additional option data
  metadata   Json?
  
  @@map("question_option_templates")
  @@unique([questionId, order])
}

// ===== CONTENT GENERATION & AI INTEGRATION =====

model ContentGenerationRequest {
  id          String @id @default(uuid())
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Request details
  requestType GenerationType // COURSE, MODULE, LESSON, ACTIVITY, ASSESSMENT
  targetId    String?        // ID of course/module/lesson to generate for
  
  // Generation parameters
  parameters  Json           // AI generation parameters
  prompt      String?        // Custom prompt
  provider    String         @default("claude") // claude, openai, etc.
  
  // Generation results
  status      GenerationStatus @default(PENDING)
  result      Json?          // Generated content
  error       String?        // Error message if failed
  
  // Metadata
  estimatedTokens Int?
  actualTokens   Int?
  processingTime Int?        // In milliseconds
  
  requestedBy String
  requester   User @relation("ContentRequests", fields: [requestedBy], references: [id])
  requestedAt DateTime @default(now())
  completedAt DateTime?
  
  @@map("content_generation_requests")
}

